# ============================================================
# .env.example — Environment variables template
# Author: Ali Boussecsou — ali-n8n.com
#
# Copy this file to .env and fill in all values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# This file (.env.example) is safe to commit — values are empty.
# ============================================================

# ── N8N ───────────────────────────────────────────────────

# Encrypts all credentials stored in the n8n database.
# Generate: openssl rand -hex 32
# WARNING: changing this value will invalidate all stored credentials.
N8N_ENCRYPTION_KEY=

# n8n Enterprise license activation key.
# Obtain from your n8n.io account.
N8N_LICENSE_ACTIVATION_KEY=

# Restricts n8n file system access to this path only.
# Must match the Docker volume mount target (read-only).
# Default: /data/metrics
N8N_RESTRICT_FILE_ACCESS_TO=

# ── REDIS ─────────────────────────────────────────────────

# Redis authentication password.
# Generate: openssl rand -hex 24
# Must match the password used in the Redis credential in n8n.
REDIS_PASSWORD=
